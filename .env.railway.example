# IronClaw Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
# Options: libsql (embedded), postgres
DATABASE_BACKEND=libsql

# For PostgreSQL (optional):
# DATABASE_URL=postgres://user:password@host:5432/ironclaw

# ─── LLM Provider ─────────────────────────────────────────────────────────
# Options: nearai, openai, anthropic, ollama, openrouter, etc.
LLM_BACKEND=openrouter

# ─── OpenRouter (used when LLM_BACKEND=openrouter) ───────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# ─── Alternative: Direct OpenAI ───────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Alternative: Anthropic ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Alternative: Ollama (local) ─────────────────────────────────────────
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Security ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRETS_MASTER_KEY=generate-a-random-key-here

# ─── Web Gateway ───────────────────────────────────────────────────────────
GATEWAY_ENABLED=true
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
GATEWAY_AUTH_TOKEN=your-secure-auth-token

# ─── Agent Settings ───────────────────────────────────────────────────────
AGENT_NAME=ironclaw
CLI_ENABLED=false

# ─── Docker Settings ───────────────────────────────────────────────────────
IRONCLAW_IN_DOCKER=false

# ─── Skip Onboarding (for automated deployments) ───────────────────────────
ONBOARD_COMPLETED=true

# ─── Logging ───────────────────────────────────────────────────────────────
RUST_LOG=ironclaw=info,tower_http=debug

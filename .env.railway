# IronClaw Deployment Configuration
# Copy this file to .env and fill in your values

# ─── Database ────────────────────────────────────────────────────────────────
# Using embedded libSQL (no external database needed)
DATABASE_BACKEND=libsql

# ─── LLM Provider: OpenRouter ────────────────────────────────────────────────
LLM_BACKEND=openrouter
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# Also set for compatibility
LLM_MODEL=qwen/qwen3.6-plus:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a random key: openssl rand -hex 32
SECRETS_MASTER_KEY=YOUR_RANDOM_KEY_HERE

# ─── Web Gateway ─────────────────────────────────────────────────────────────
GATEWAY_ENABLED=true
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=3000
GATEWAY_AUTH_TOKEN=your-secure-auth-token-here

# ─── Agent ───────────────────────────────────────────────────────────────────
AGENT_NAME=ironclaw
CLI_ENABLED=false

# ─── Docker Settings ─────────────────────────────────────────────────────────
IRONCLAW_IN_DOCKER=true

# ─── Skip Onboarding ─────────────────────────────────────────────────────────
ONBOARD_COMPLETED=true

# ─── Logging ─────────────────────────────────────────────────────────────────
RUST_LOG=ironclaw=info
